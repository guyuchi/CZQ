---
// src/components/Hero.astro
import { useTranslations, type Lang } from '../i18n/utils';

export interface Props {
  currentLang: Lang;
}

const { currentLang } = Astro.props;
const t = useTranslations(currentLang);
---

<section class="hero">
  <div class="container hero-inner">
    <div class="hero-image">
      <img src="/images/profile.jpg" alt="Profile" class="profile-photo" width="180" height="180" />
    </div>
    <div class="hero-text">
      <h1 class="hero-name">Dr. [Name]</h1>
      <p class="hero-title">{t.hero.title}</p>
      <p class="hero-bio">
        Educational Technology researcher passionate about leveraging technology to enhance learning experiences. Exploring innovative pedagogical approaches and digital learning environments.
      </p>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: calc(var(--nav-height) + var(--space-16)) 0 var(--space-12);
  }
  .hero-inner {
    display: flex;
    align-items: center;
    gap: var(--space-12);
  }
  .hero-image { flex-shrink: 0; }
  .profile-photo {
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid var(--color-surface);
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
  }
  .hero-text { flex: 1; }
  .hero-name {
    font-size: var(--font-size-3xl);
    margin-bottom: var(--space-2);
  }
  .hero-title {
    font-size: var(--font-size-lg);
    color: var(--color-secondary);
    margin-bottom: var(--space-4);
    font-weight: 500;
  }
  .hero-bio {
    color: var(--color-text);
    line-height: 1.8;
    max-width: 540px;
  }
  @media (max-width: 640px) {
    .hero-inner {
      flex-direction: column;
      text-align: center;
    }
    .hero-bio { max-width: 100%; }
  }
</style>

  .pub-authors { font-size: var(--font-size-sm); color: var(--color-text-muted); }
  .pub-venue { font-size: var(--font-size-sm); color: var(--color-secondary); margin-bottom: var(--space-2); }
  .pub-badge { display: inline-block; font-size: var(--font-size-xs); background: var(--color-bg); padding: 1px 6px; border-radius: 3px; color: var(--color-primary); font-style: normal; }
  .pub-link { font-size: var(--font-size-sm); font-weight: 500; }
  h3 { margin-top: var(--space-8); margin-bottom: var(--space-4); }
</style>

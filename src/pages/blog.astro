---
import DetailLayout from '../layouts/DetailLayout.astro';
import { getCollection, render } from 'astro:content';
import { useTranslations } from '../i18n/utils';
import { getLangFromUrl } from '../i18n/utils';

const currentLang = getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);

const allEntries = await getCollection('zh');
const blogEntries = allEntries
  .filter(entry => entry.id.startsWith('blog/'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const posts = await Promise.all(
  blogEntries.map(async (entry) => {
    const { Content } = await render(entry);
    return { data: entry.data, Content };
  })
);
---

<DetailLayout title="博客 - Ziqi Chen" description={t.blog.title}>
  <h2>{t.blog.title}</h2>
  {posts.length > 0 ? (
    posts.map(({ data, Content }) => (
      <article class="blog-post">
        <h3>{data.title}</h3>
        <time datetime={data.date instanceof Date ? data.date.toISOString() : data.date}>
          {data.date instanceof Date
            ? data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })
            : data.date}
        </time>
        <p class="blog-description">{data.description}</p>
        <Content />
      </article>
    ))
  ) : (
    <p>{t.blog.noPosts}</p>
  )}
</DetailLayout>

<style>
  .blog-post {
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }
  .blog-post:last-child {
    border-bottom: none;
  }
  .blog-post time {
    display: block;
    color: var(--color-secondary);
    font-size: var(--font-size-sm);
    margin-bottom: var(--space-2);
  }
  .blog-description {
    color: var(--color-text);
    margin-bottom: var(--space-4);
    font-style: italic;
  }
</style>

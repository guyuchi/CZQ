---
import DetailLayout from '../layouts/DetailLayout.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const currentLang = getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);
---

<DetailLayout title="联系方式 - Ziqi Chen" description="Get in touch">
  <h2>{t.sections.contact}</h2>

  <div class="contact-info">
    <p><strong>Email:</strong> ziqichentech@hotmail.com</p>
  </div>

  <form class="contact-form" action="https://formspree.io/f/YOUR_FORM_ID" method="POST">
    <label>
      <span>{t.contact.name}</span>
      <input type="text" name="name" required />
    </label>
    <label>
      <span>{t.contact.email}</span>
      <input type="email" name="email" required />
    </label>
    <label>
      <span>{t.contact.message}</span>
      <textarea name="message" rows="5" required></textarea>
    </label>
    <button type="submit" class="btn">{t.common.send}</button>
  </form>
</DetailLayout>

<style>
  .contact-info { margin-bottom: var(--space-8); }
  .contact-form label {
    display: block;
    margin-bottom: var(--space-4);
  }
  .contact-form span {
    display: block;
    font-size: var(--font-size-sm);
    font-weight: 500;
    margin-bottom: var(--space-1);
    color: var(--color-text);
  }
  .contact-form input,
  .contact-form textarea {
    width: 100%;
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    font-family: var(--font-sans);
    font-size: var(--font-size-base);
    background: var(--color-surface);
  }
  .contact-form input:focus,
  .contact-form textarea:focus {
    outline: none;
    border-color: var(--color-primary);
  }
</style>

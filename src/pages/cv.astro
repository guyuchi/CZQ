  <section>
    <h3>教育背景</h3>
    <p>Coming soon: Education history</p>
  </section>

  <section>
    <h3>研究经历</h3>
    <p>Coming soon: Research experience</p>
  </section>

  <section>
    <h3>荣誉与奖项</h3>
    <p>Coming soon: Awards and honors</p>
  </section>

  <div style="margin-top: var(--space-8)">
    <a href="/cv.pdf" class="btn" download>下载简历 (PDF)</a>
  </div>
</DetailLayout>

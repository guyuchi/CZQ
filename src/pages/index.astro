---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import { useTranslations, getLangFromUrl } from '../i18n/utils';

const currentLang = getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);
const isZh = currentLang === 'zh';
---

<BaseLayout title="陈子淇 - 教育技术 · 个人主页" description="Educational Technology researcher personal website">
  <Hero currentLang={currentLang} />

  <section class="section container">
    <h2>{t.sections.research}</h2>
    {isZh ? (
      <>
        <p>我的研究聚焦于人工智能在教育中的应用，主要研究方向包括：</p>
        <ul>
          <li><strong>AI in Education</strong> — 人工智能技术在教育场景中的整合与应用</li>
          <li><strong>AI-Assisted Learning Assessment</strong> — 基于人工智能的学习评估方法</li>
          <li><strong>Feedback Practice</strong> — 学习反馈机制与实践研究</li>
          <li><strong>Educational Data Mining and Analysis</strong> — 教育数据挖掘与分析</li>
          <li><strong>Emotions in Learning</strong> — 学习过程中的情感因素研究</li>
        </ul>
      </>
    ) : (
      <>
        <p>My research focuses on the application of Artificial Intelligence in education, with specific interests in:</p>
        <ul>
          <li><strong>AI in Education</strong> — Integration and application of AI technologies in educational settings</li>
          <li><strong>AI-Assisted Learning Assessment</strong> — AI-driven approaches to learning evaluation</li>
          <li><strong>Feedback Practice</strong> — Feedback mechanisms and practices in learning</li>
          <li><strong>Educational Data Mining and Analysis</strong> — Mining and analyzing educational data</li>
          <li><strong>Emotions in Learning</strong> — Affective factors in the learning process</li>
        </ul>
      </>
    )}
  </section>

  <section class="section container">
    <h2>{isZh ? '教育背景' : 'Education'}</h2>
    <ul>
      <li><strong>{isZh ? '澳门理工大学 (MPU)' : 'Macao Polytechnic University (MPU)'}</strong> — {isZh ? '教育技术与创新 哲学博士' : 'PhD in Educational Technology and Innovation'}, 2023.08 - 2026.09</li>
      <li><strong>{isZh ? '澳门大学 (UM)' : 'University of Macau (UM)'}</strong> — {isZh ? '数据科学 理学硕士' : 'MSc in Data Science'}, 2021.08 - 2023.06</li>
      <li><strong>{isZh ? '广东工业大学 (GDUT)' : 'Guangdong University of Technology (GDUT)'}</strong> — {isZh ? '应用统计学 理学学士' : 'BSc in Applied Statistics'}, 2017.09 - 2021.06</li>
    </ul>
  </section>

  <section class="section container">
    <h2>{isZh ? '研究经历' : 'Research Experience'}</h2>
    <ul>
      <li><strong>{isZh ? '整合生成式AI聊天机器人与学术写作及反馈实践' : 'Integrating Generative AI Chatbots with Academic Writing and Feedback Practice'}</strong> — {isZh ? '澳门理工大学资助项目' : 'MPU Funded Project'} (2023.08-2026.08), {isZh ? '核心成员' : 'Core Member'}</li>
      <li><strong>{isZh ? '信任、情感与参与度：生成式AI在教育与专业环境中的交互研究' : 'Trust, Emotions and Engagement While Interacting with GenAI Output'}</strong> — {isZh ? '澳门理工大学资助项目' : 'MPU Funded Project'} (2025.07-2028.07), {isZh ? '核心成员' : 'Core Member'}</li>
      <li><strong>{isZh ? '博士研讨会：学习情感的测量与分析' : 'PhD Seminar: Measuring and Analyzing Students\' Emotions in Learning'}</strong> — {isZh ? '主讲人' : 'Main Speaker'} (2025.04)</li>
    </ul>
  </section>

  <section class="section container">
    <h2>{isZh ? '专业技能' : 'Skills'}</h2>
    <ul>
      <li><strong>{isZh ? '编程：' : 'Programming: '}</strong> Python, R, Tableau, SPSS</li>
      <li><strong>{isZh ? '语言：' : 'Languages: '}</strong> {isZh ? '英语 (全英教学), 粤语, 普通话, 日语 (N5)' : 'English (Full English Instruction), Cantonese, Mandarin, Japanese (N5)'}</li>
    </ul>
  </section>

  <div class="section container" style="margin-top: var(--space-4)">
    <a href="/CV2026-CHEN_ZIQI.docx" class="btn" download>{isZh ? '下载简历 (DOCX)' : 'Download CV (DOCX)'}</a>
  </div>

  <section class="section container">
    <h2>{t.sections.contact}</h2>
    <div class="social-links">
      <a href="mailto:ziqichentech@hotmail.com" class="social-link" target="_blank" rel="noopener noreferrer">
        <svg class="social-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"/></svg>
        ziqichentech@hotmail.com
      </a>
      <a href="https://x.com/ZiqiChen" class="social-link" target="_blank" rel="noopener noreferrer">
        <svg class="social-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        X (Twitter)
      </a>
      <a href="https://scholar.google.com/citations?user=YOUR_ID" class="social-link" target="_blank" rel="noopener noreferrer">
        <svg class="social-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M5.242 13.769L0 9.5 12 0l12 9.5-5.242 4.269C17.548 11.249 14.978 9.5 12 9.5c-2.977 0-5.548 1.748-6.758 4.269zM12 10a7 7 0 1 0 0 14 7 7 0 0 0 0-14z"/></svg>
        Google Scholar
      </a>
      <a href="https://www.linkedin.com/in/ziqichen" class="social-link" target="_blank" rel="noopener noreferrer">
        <svg class="social-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        LinkedIn
      </a>
      <a href="https://orcid.org/0000-0000-0000-0000" class="social-link" target="_blank" rel="noopener noreferrer">
        <svg class="social-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zM7.369 4.378c.525 0 .947.431.947.947s-.422.947-.947.947a.95.95 0 0 1-.947-.947c0-.525.422-.947.947-.947zm-.722 3.038h1.444v10.041H6.647V7.416zm3.562 0h3.9c3.712 0 5.344 2.653 5.344 5.025 0 2.578-2.016 5.025-5.325 5.025h-3.919V7.416zm1.444 1.303v7.444h2.297c3.272 0 4.022-2.484 4.022-3.722 0-2.016-1.284-3.722-3.903-3.722h-2.416z"/></svg>
        ORCID
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .social-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .social-link {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    font-size: var(--font-size-base);
    transition: all 0.2s;
    width: fit-content;
  }
  .social-link:hover {
    border-color: var(--color-primary);
    transform: translateX(4px);
  }
  .social-icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }
</style>

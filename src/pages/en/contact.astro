---
import DetailLayout from '../../layouts/DetailLayout.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const currentLang = getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);
---

<DetailLayout title="Contact - Ziqi Chen" description="Get in touch">
  <h2>{t.sections.contact}</h2>

  <div class="contact-info">
    <p><strong>Email:</strong> ziqichentech@hotmail.com</p>
  </div>

  <div class="social-links">
    <a href="https://x.com/ZiqiChen" class="social-link" target="_blank" rel="noopener noreferrer">X (Twitter)</a>
    <a href="https://scholar.google.com/citations?user=YOUR_ID" class="social-link" target="_blank" rel="noopener noreferrer">Google Scholar</a>
    <a href="https://www.linkedin.com/in/ziqichen" class="social-link" target="_blank" rel="noopener noreferrer">LinkedIn</a>
    <a href="https://orcid.org/0000-0000-0000-0000" class="social-link" target="_blank" rel="noopener noreferrer">ORCID</a>
  </div>
</DetailLayout>

<style>
  .contact-info { margin-bottom: var(--space-8); }
  .social-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .social-link {
    display: inline-block;
    padding: var(--space-2) var(--space-4);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    font-size: var(--font-size-base);
    transition: all 0.2s;
    width: fit-content;
  }
  .social-link:hover {
    border-color: var(--color-primary);
    transform: translateX(4px);
  }
</style>
